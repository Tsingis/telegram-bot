{
  "name": "telegram-bot-iac",
  "description": "Telegram bot IaC",
  "main": "resources/index.ts",
  "engineStrict": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "prettier --check 'resources/*.{js,ts,json,yml}'",
    "format:fix": "prettier --write 'resources/*.{js,ts,json,yml}'",
    "typecheck": "tsc --noEmit",
    "stack": "pulumi stack select ",
    "refresh": "pulumi refresh",
    "preview": "pulumi preview",
    "up": "pulumi up"
  },
  "dependencies": {
    "@pulumi/aws": "^7.28.0",
    "@pulumi/pulumi": "^3.233.0"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "tar": "^7.5.6"
  }
}
